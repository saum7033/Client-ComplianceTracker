{
  "version": 2,
  "name": "ctms-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://Client-ComplianceTracker.railway.app/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_BASE_URL": "/api"
  },
  "build": {
    "env": {
      "REACT_APP_API_BASE_URL": "/api"
    }
  },
  "functions": {},
  "regions": ["iad1"],
  "framework": "create-react-app"
}
