// Compliance Tracker Database Schema
// Mini Compliance Tracker for LedgersCFO

Table clients {
  id integer [primary key]
  company_name varchar [not null]
  country varchar [not null]
  entity_type varchar [not null]
  created_at timestamp [default: 'now()']
}

Table compliance_tasks {
  id integer [primary key]
  client_id integer [not null]
  title varchar [not null]
  description text
  category varchar [not null]
  due_date date [not null]
  status varchar [not null, note: 'Pending, In Progress, Completed, Overdue']
  priority varchar [not null, note: 'High, Medium, Low']
  created_at timestamp [default: 'now()']
  updated_at timestamp [default: 'now()']
}

// Relationships
Ref client_tasks: compliance_tasks.client_id > clients.id // many-to-one

// Sample data
Records clients(id, company_name, country, entity_type) {
  1, 'TechCorp Inc.', 'United States', 'LLC'
  2, 'Global Finance Ltd.', 'United Kingdom', 'Limited'
  3, 'Startup Ventures', 'Canada', 'Corporation'
